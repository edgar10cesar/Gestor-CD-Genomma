# Firebase Configuration (Automatically managed by AI Studio when setup is run)
# VITE_FIREBASE_CONFIG=

# Email Service (Gmail SMTP)
# Use your full Gmail address
GMAIL_USER=
# Create an App Password at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=
# The email address that will appear as the sender (usually same as GMAIL_USER)
GMAIL_FROM=
# The name that will appear as the sender
GMAIL_FROM_NAME=Sistema de Inventário
